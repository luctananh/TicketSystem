generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUM
enum Role {
  ADMIN
  TESTER
  DEV
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TicketUserRole {
  DEV
  TESTER
}

// USER
model User {
  // ===== Fields =====
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(TESTER)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  // ===== Relations =====
  createdTickets Ticket[]     @relation("CreatedTickets")
  comments       Comment[]
  ticketUsers    TicketUser[]
}

// TICKET
model Ticket {
  // ===== Fields =====
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(MEDIUM)

  createdBy Int

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // ===== Relations =====
  creator     User         @relation("CreatedTickets", fields: [createdBy], references: [id])
  ticketUsers TicketUser[]
  comments    Comment[]

  // ===== Index =====
  @@index([status])
  @@index([createdBy])
}

// TICKET USER
model TicketUser {
  // ===== Fields =====
  id       Int @id @default(autoincrement())
  ticketId Int
  userId   Int

  role   TicketUserRole
  isMain Boolean        @default(false)

  createdAt DateTime @default(now())

  // ===== Relations =====
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  // ===== Constraint / Index =====
  @@unique([ticketId, userId, role])
  @@index([userId])
}

// COMMENT
model Comment {
  // ===== Fields =====
  id      Int    @id @default(autoincrement())
  content String

  ticketId Int
  userId   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ===== Relations =====
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
}
